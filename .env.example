# Copy to apps/<app>/.env.local for local Vite (ai-client / some tools)
VITE_OPENAI_API_KEY=your_openai_key_here

# Production (Vercel): prefer ONE team Shared OPENAI_API_KEY (exact name, not VITE_*).
# Team Settings → Environment Variables → link that shared var to each app project,
# then Redeploy. New tools: link the new project to the same shared key (see README).
# Avoid a project-level OPENAI_API_KEY unless you want to override Shared.
# OPENAI_API_KEY=your_openai_key_here
#
# video-curator also accepts VITE_OPENAI_API_KEY as a fallback, but prefer OPENAI_API_KEY.
