{
  "extends": "@workspace/config/tsconfig",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "allowJs": true,
    "esModuleInterop": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
